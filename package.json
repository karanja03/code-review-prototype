{
	"name": "code-review-sprint",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20.18.0 <21"
	},
	"volta": {
		"node": "20.18.3"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:b": "DATABASE_URL=./data/local-b.db vite dev --port 5174",
		"dev:c": "DATABASE_URL=./data/local-c.db vite dev --port 5175",
		"build": "vite build",
		"preview": "vite build && vite preview",
		"start": "vite preview --host 0.0.0.0 --port 3000",
		"start:node": "node server.js",
		"db:push": "drizzle-kit push",
		"db:push:b": "DATABASE_URL=./data/local-b.db drizzle-kit push",
		"db:push:c": "DATABASE_URL=./data/local-c.db drizzle-kit push",
		"db:nuke": "rm -f data/local.db data/local.db-shm data/local.db-wal && npm run db:push",
		"db:studio": "drizzle-kit studio",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "node scripts/postinstall-sqlite.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@node-rs/argon2": "^2.0.2",
		"drizzle-orm": "^0.40.1",
		"lucia": "^3.2.2",
		"socket.io": "^4.8.1",
		"socket.io-client": "^4.8.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^5.2.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/vite": "^4.1.18",
		"drizzle-kit": "^0.30.6",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^6.2.0"
	}
}
